{
  "version": 1,
  "description": "API routes to Bmob proxy",
  "routes": [
    {
      "path": "/api/login",
      "functions": "api/login"
    },
    {
      "path": "/api/users",
      "functions": "api/users"
    },
    {
      "path": "/api/users/:objectId",
      "functions": "api/users"
    },
    {
      "path": "/api/:table",
      "functions": "api/bmob"
    },
    {
      "path": "/api/:table/:id",
      "functions": "api/bmob"
    }
  ]
}
